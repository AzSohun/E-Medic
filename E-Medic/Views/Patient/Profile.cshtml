@model E_Medic.Models.User

@{
    ViewData["Title"] = "Patient Profile";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3 mb-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="show" aria-label="Close"></button>
                </div>
            }

            <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
                <div class="d-flex align-items-center gap-3 border-bottom pb-4 mb-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                        <i class="bi bi-person-bounding-box display-6"></i>
                    </div>
                    <div>
                        <h3 class="fw-bold text-dark mb-1">My Personal Profile</h3>
                        <p class="text-muted small mb-0">Keep your account details and medical identity up to date.</p>
                    </div>
                </div>

                <form asp-controller="Patient" asp-action="UpdateProfile" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-semibold text-secondary">Email Address</label>
                            <input type="text" class="form-control bg-light text-muted border-0" value="@Model.Email" readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-semibold text-secondary">Account Status</label>
                            <div class="form-control bg-light text-muted border-0 d-flex align-items-center gap-2">
                                <span class="badge bg-success rounded-pill px-2.5">Active Patient</span>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="FullName" class="form-label small fw-semibold text-secondary">Full Name *</label>
                            <input asp-for="FullName" type="text" class="form-control border shadow-sm" placeholder="Enter your full name" required />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DateOfBirth" class="form-label small fw-semibold text-secondary">Date of Birth</label>
                            <input asp-for="DateOfBirth" type="date" class="form-control border shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Gender" class="form-label small fw-semibold text-secondary">Gender</label>
                            <select asp-for="Gender" class="form-select border shadow-sm">
                                <option value="">Select Gender</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm" style="background-color: #0d6efd !important; border: none;">
                            Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>