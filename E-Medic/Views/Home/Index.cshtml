@{
    ViewData["Title"] = "E-Medic - Digital Triage & Premium Telehealth";
}

<!-- 📦 Core Icon Engine -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --md-primary: #0284c7; /* Clinical Trust Blue */
        --md-secondary: #0ea5e9; /* Soft Sky Blue */
        --md-success: #10b981; /* Mint Green */
        --md-dark: #0f172a; /* Slate Dark Header */
        --md-body: #475569; /* Readable Slate Body */
        --md-bg-light: #f8fafc; /* Clean Light Background */
        --md-border: #e2e8f0; /* Minimalist Border */
    }

    body {
        background-color: #ffffff;
        color: var(--md-body);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        scroll-behavior: smooth;
    }

    /* 🎯 Hero Badges */
    .hero-badge {
        background-color: rgba(2, 132, 199, 0.08);
        color: var(--md-primary);
        font-weight: 600;
        font-size: 0.85rem;
    }

    /* 💳 Premium Flat Section Cards */
    .medical-card {
        background: #ffffff;
        border: 1px solid var(--md-border);
        border-radius: 16px;
        padding: 35px 28px;
        height: 100%;
        transition: all 0.2s ease-in-out;
        position: relative;
        overflow: hidden; /* 🛡️ ভেতরের এলিমেন্ট যেন বর্ডার ভেঙে বাইরে না যায় */
    }

        .medical-card:hover {
            border-color: #cbd5e1;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.04);
            transform: translateY(-2px);
        }

    .medical-icon-box {
        width: 52px;
        height: 52px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        font-weight: bold;
    }

    /* 🔘 Minimalist Buttons & Link Fixes */
    .card-action-link {
        color: var(--md-primary);
        font-weight: 600;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        position: relative;
        z-index: 2; /* 🚀 বোতামের লেয়ার ফিক্স */
        transition: color 0.15s ease;
    }

        .card-action-link.secondary-link {
            color: var(--md-secondary);
        }

        .card-action-link.success-link {
            color: var(--md-success);
        }

    .btn-md-primary {
        background-color: var(--md-primary);
        color: #ffffff !important;
        font-weight: 600;
        font-size: 0.9rem;
        border: none;
        border-radius: 12px;
        padding: 13px 32px;
        transition: background-color 0.15s ease;
    }

        .btn-md-primary:hover {
            background-color: #0369a1;
        }

    .btn-md-outline {
        background-color: transparent;
        border: 1px solid #cbd5e1;
        color: var(--md-dark);
        font-weight: 500;
        font-size: 0.9rem;
        border-radius: 12px;
        padding: 12px 28px;
        transition: all 0.15s ease;
    }

        .btn-md-outline:hover {
            background-color: #f8fafc;
            border-color: #94a3b8;
        }

    /* 🔍 Search Core Panel */
    .search-console-wrapper {
        background: #ffffff;
        border: 1px solid #cbd5e1;
        border-radius: 14px;
        padding: 6px 8px;
        width: 100%;
        max-width: 520px;
    }

        .search-console-wrapper:focus-within {
            border-color: var(--md-primary);
            box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.15);
        }

    /* 🧑‍⚕️ Professional Thumbnails */
    .doctor-thumbnail {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        object-fit: cover;
        background-color: #f1f5f9;
    }

    /* 📊 Membership Premium Cards */
    .membership-card {
        background: #ffffff;
        border: 1px solid var(--md-border);
        border-radius: 20px;
        padding: 40px 30px;
        position: relative;
        height: 100%;
        overflow: hidden;
    }

        .membership-card.featured {
            border: 2px solid var(--md-primary);
            box-shadow: 0 10px 25px rgba(2, 132, 199, 0.05);
        }
</style>

<!-- ========================================== 🏥 ১. HERO SECTION ========================================== -->
<section class="py-5" style="margin-top: 30px;">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 text-center text-lg-start">
                <span class="badge hero-badge rounded-pill px-3 py-2 mb-3">
                    <i class="bi bi-shield-check me-1"></i> Verified Digital Healthcare Network
                </span>
                <h1 class="display-5 fw-bold text-dark mb-3" style="font-weight: 700; letter-spacing: -1px; color: var(--md-dark) !important;">
                    Your Health, Managed <br><span style="color: var(--md-primary);">Simply & Securely.</span>
                </h1>
                <p class="fs-5 text-muted mb-4" style="line-height: 1.6; max-width: 520px;">
                    Skip clinic waiting times. Book instant virtual consultations with certified doctors, manage medical prescriptions, and track health histories seamlessly.
                </p>

                <div class="search-console-wrapper d-flex flex-column flex-sm-row gap-2 align-items-center mb-3">
                    <div class="d-flex align-items-center gap-2 px-2 w-100">
                        <i class="bi bi-search text-muted"></i>
                        <input type="text" class="form-control border-0 bg-transparent p-2 shadow-none" placeholder="Search doctors, specialties, or departments..." style="font-size: 0.92rem; color: var(--md-dark);" />
                    </div>
                    <button class="btn btn-md-primary py-2 w-100 w-sm-auto px-4">Find Doctor</button>
                </div>
            </div>

            <div class="col-lg-6 text-center">
                <img src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&fit=crop&w=580&q=80"
                     alt="E-Medic Healthcare Portal" class="img-fluid rounded-4 border shadow-sm" style="max-height: 380px; object-fit: cover;">
            </div>
        </div>
    </div>
</section>

<!-- ========================================== 🛠️ ২. SERVICES SECTION ========================================== -->
<section id="services" class="py-5 border-top border-bottom" style="background-color: var(--md-bg-light); padding: 80px 0 !important;">
    <div class="container">
        <div class="mb-5 text-center mx-auto" style="max-width: 600px;">
            <h2 class="fw-bold text-dark h1" style="letter-spacing: -0.5px; color: var(--md-dark) !important;">Core Patient Services</h2>
            <p class="text-muted">Reliable digital medical workflows optimized for immediate primary healthcare delivery.</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="medical-card">
                    <div class="medical-icon-box mb-4" style="background-color: rgba(2, 132, 199, 0.08); color: var(--md-primary);">
                        <i class="bi bi-camera-video-fill"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark mb-2">Video Consultation</h3>
                    <p class="small text-secondary mb-4" style="line-height: 1.6;">Connect securely with board-certified physicians from any location via professional encrypted tele-channels.</p>
                    <a href="#" class="text-decoration-none card-action-link">Book Consultation <i class="bi bi-chevron-right fs-6"></i></a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="medical-card">
                    <div class="medical-icon-box mb-4" style="background-color: rgba(14, 165, 233, 0.08); color: var(--md-secondary);">
                        <i class="bi bi-capsule-pill"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark mb-2">Prescription Pharmacy</h3>
                    <p class="small text-secondary mb-4" style="line-height: 1.6;">Upload verified digital prescriptions to dispatch essential health medications straight to your address.</p>
                    <a href="#" class="text-decoration-none card-action-link secondary-link">Order Medicine <i class="bi bi-chevron-right fs-6"></i></a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="medical-card">
                    <div class="medical-icon-box mb-4" style="background-color: rgba(16, 185, 129, 0.08); color: var(--md-success);">
                        <i class="bi bi-folder-fill"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark mb-2">Secure Health Records</h3>
                    <p class="small text-secondary mb-4" style="line-height: 1.6;">Access historical clinical logs, diagnostic laboratory metrics, and prescriptions in a protected profile vault.</p>
                    <a href="#" class="text-decoration-none card-action-link success-link">View Repository <i class="bi bi-chevron-right fs-6"></i></a>
                </div>
            </div>
        </div>
    </div>
</section>


<!-- ========================================== 🏢 ৪. ABOUT US SECTION ========================================== -->
<section id="about" class="py-5 border-top" style="padding: 80px 0 !important;">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-md-6">
                <img src="https://images.unsplash.com/photo-1516549655169-df83a0774514?auto=format&fit=crop&w=580&q=80"
                     alt="Medical Infrastructure" class="img-fluid rounded-4 border shadow-sm">
            </div>
            <div class="col-md-6">
                <span class="badge hero-badge rounded-pill px-3 py-2 mb-3">OUR CORE IDENTITY</span>
                <h2 class="fw-bold text-dark mb-3" style="letter-spacing: -0.5px;">Next-Gen Telehealth Infrastructure</h2>
                <p class="text-secondary mb-4" style="line-height: 1.7;">
                    E-Medic is a unified digital health ecosystem engineered to eliminate operational latencies within primary care facilities. By deploying optimized database relation pipelines and secure data routing, we enable zero-lag connectivity between certified physicians and patients nationwide.
                </p>
                <div class="row g-3">
                    <div class="col-6">
                        <h4 class="fw-bold text-dark mb-1">100% Secure</h4>
                        <p class="small text-muted mb-0">Zero-knowledge health record vault encryption.</p>
                    </div>
                    <div class="col-6">
                        <h4 class="fw-bold text-dark mb-1">Elite Specialists</h4>
                        <p class="small text-muted mb-0">Fully vetted, verified and board-certified practitioners.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="container my-5 py-4">
    <div class="p-5 text-center rounded-4 border bg-white shadow-sm">
        <h2 class="h3 fw-bold text-dark mb-2" style="letter-spacing: -0.5px;">Ready to consult with a medical professional?</h2>
        <p class="text-muted mx-auto mb-4 small" style="max-width: 500px;">Register an account in a few seconds, complete your registration profile, and secure your online appointment immediately.</p>
        <div class="d-flex justify-content-center">
            <a href="#" class="btn btn-md-primary px-5 py-2.5">Schedule Appointment Now</a>
        </div>
    </div>
</section>