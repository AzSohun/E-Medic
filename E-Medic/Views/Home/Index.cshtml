@{
    ViewData["Title"] = "E-Medic - Modern Digital Triage & Telehealth";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --clinical-blue: #0284c7;
        --clinical-cyan: #06b6d4;
        --clinical-mint: #10b981;
        --text-heading: #0f172a;
        --text-body: #475569;
        --bg-soft: #f8fafc;
        --bg-mint-soft: #f0fdf4;
    }

    body {
        background-color: #ffffff;
        color: var(--text-body);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    /* Ambient soft background glow */
    .clinical-glow {
        position: absolute;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(6, 182, 212, 0.04) 0%, rgba(255,255,255,0) 70%);
        top: -10%;
        right: -5%;
        z-index: -1;
        pointer-events: none;
    }

    .section-gap {
        padding: 80px 0;
    }

    /* Sleek Clinic Card System */
    .clinic-feature-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        padding: 35px 25px;
        height: 100%;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

        .clinic-feature-card:hover {
            transform: translateY(-5px);
            border-color: rgba(6, 182, 212, 0.3);
            box-shadow: 0 15px 30px rgba(6, 182, 212, 0.04);
        }

    .clinic-icon-shape {
        width: 52px;
        height: 52px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        margin-bottom: 20px;
    }

    /* Premium Pill Buttons */
    .btn-clinic-primary {
        background: linear-gradient(135deg, var(--clinical-cyan) 0%, var(--clinical-blue) 100%);
        color: #ffffff !important;
        border: none;
        border-radius: 50px;
        padding: 13px 32px;
        font-weight: 600;
        box-shadow: 0 4px 14px rgba(6, 182, 212, 0.2);
        transition: all 0.2s ease;
    }

        .btn-clinic-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(2, 132, 199, 0.3);
        }

    .btn-clinic-outline {
        border: 1px solid #cbd5e1;
        background: transparent;
        color: var(--text-heading);
        border-radius: 50px;
        padding: 12px 32px;
        font-weight: 500;
        transition: all 0.2s ease;
    }

        .btn-clinic-outline:hover {
            background: #f8fafc;
            border-color: #94a3b8;
        }

    /* Quick Action Search Bar */
    .search-panel {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 100px;
        padding: 8px 12px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.02);
    }

    /* Re-engineered Premium Subscription Membership Cards */
    .sub-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
    }

        .sub-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(15, 23, 42, 0.05);
        }

    /* Highlighting the Featured Middle Plan */
    .sub-card-featured {
        border: 2px solid var(--clinical-cyan) !important;
        background: radial-gradient(circle at 100% 0%, rgba(6, 182, 212, 0.03) 0%, #ffffff 100%);
    }

    .sub-feature-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .sub-feature-list li {
            font-size: 0.9rem;
            color: var(--text-body);
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 14px;
        }

            .sub-feature-list li i {
                font-size: 1.1rem;
            }

    /* Specialist Grid Circle Overrides */
    .avatar-frame {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #ffffff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }
</style>

<div class="clinical-glow"></div>

<!-- ========================= HERO CLINICAL DIRECTORY ========================= -->
<section class="py-5" style="margin-top: 20px;">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 text-center text-lg-start" data-aos="fade-right" data-aos-duration="700">
                <div class="d-inline-flex align-items-center gap-2 bg-info bg-opacity-10 text-info fw-semibold rounded-pill px-3 py-1.5 mb-3 small" style="font-size: 0.82rem;">
                    <i class="bi bi-patch-check-fill"></i> Your Trusted Virtual Primary Care
                </div>
                <h1 class="display-4 fw-bold text-dark mb-3" style="font-weight: 800; letter-spacing: -1px; line-height: 1.2;">
                    Healthcare Made <br><span style="color: var(--clinical-blue);">Simple, Swift & Smart</span>
                </h1>
                <p class="fs-5 text-muted mb-4" style="line-height: 1.7; max-width: 520px;">
                    Skip the stress of busy clinic waiting blocks. Book immediate consultations with premium certified doctors, request doorstep pharmacy deliveries, and track health vitals on one clinical portal.
                </p>

                <!-- Quick Interaction Search Panel -->
                <div class="search-panel d-flex flex-column flex-sm-row gap-2 align-items-center max-width-500 mb-4 me-lg-4">
                    <div class="d-flex align-items-center gap-2 px-3 w-100">
                        <i class="bi bi-search text-muted"></i>
                        <input type="text" class="form-control border-0 bg-transparent p-1 shadow-none small" placeholder="Search doctors, specialties, or medical conditions..." style="font-size: 0.9rem;" />
                    </div>
                    <button class="btn btn-clinic-primary py-2.5 w-100 w-sm-auto px-4" style="border-radius: 50px; font-size: 0.88rem;">Find Doctor</button>
                </div>
            </div>

            <div class="col-lg-6 text-center" data-aos="zoom-in" data-aos-duration="900">
                <div class="position-relative d-inline-block">
                    <img src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&fit=crop&w=650&q=80"
                         alt="Modern Clinical Care" class="img-fluid rounded-4 shadow-lg" style="max-height: 400px; object-fit: cover;">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========================= CLINICAL OPERATIONS CARD MATRIX ========================= -->
<section id="services" class="section-gap bg-light bg-opacity-50 border-top border-bottom">
    <div class="container">
        <div class="text-center mb-5 max-width-600 mx-auto" data-aos="fade-up">
            <h2 class="h1 fw-bold text-dark" style="letter-spacing: -0.5px;">Our Patient Services</h2>
            <p class="text-muted mt-2">Comprehensive health workflows optimized for your family's care.</p>
        </div>

        <div class="row g-4">
            <!-- Video Consultation -->
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                <div class="clinic-feature-card">
                    <div class="clinic-icon-shape" style="background: rgba(2, 132, 199, 0.08); color: var(--clinical-blue);">
                        <i class="bi bi-camera-video"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark mb-2">Video Consultation</h3>
                    <p class="text-secondary small mb-4" style="line-height: 1.6;">Connect instantly via clear HD video channels with certified medical specialists from any terminal securely.</p>
                    <a href="#" class="text-info text-decoration-none fw-semibold small d-inline-flex align-items-center gap-1" style="color: var(--clinical-blue) !important;">Book a Slot <i class="bi bi-chevron-right"></i></a>
                </div>
            </div>
            <!-- Online Pharmacy -->
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                <div class="clinic-feature-card">
                    <div class="clinic-icon-shape" style="background: rgba(6, 182, 212, 0.08); color: var(--clinical-cyan);">
                        <i class="bi bi-capsule"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark mb-2">Prescription Pharmacy</h3>
                    <p class="text-secondary small mb-4" style="line-height: 1.6;">Drop your script logs down into our dispatcher dashboard to clear fast home deliveries for verified medications.</p>
                    <a href="#" class="text-info text-decoration-none fw-semibold small d-inline-flex align-items-center gap-1" style="color: var(--clinical-cyan) !important;">Order Medicine <i class="bi bi-chevron-right"></i></a>
                </div>
            </div>
            <!-- Secure Health Records -->
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                <div class="clinic-feature-card">
                    <div class="clinic-icon-shape" style="background: rgba(16, 185, 129, 0.08); color: var(--clinical-mint);">
                        <i class="bi bi-file-earmark-medical"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark mb-2">Secure Health Records</h3>
                    <p class="text-secondary small mb-4" style="line-height: 1.6;">Access and map your entire historical laboratory reports and vitals ledger under absolute encryption protocols.</p>
                    <a href="#" class="text-success text-decoration-none fw-semibold small d-inline-flex align-items-center gap-1" style="color: var(--clinical-mint) !important;">View Vault <i class="bi bi-chevron-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</section>

