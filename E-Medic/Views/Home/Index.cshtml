@{
    ViewData["Title"] = "E-Medic - Premium Healthcare Solutions";
}

<!-- Custom CSS for Modern Cyan-Lime Gradient UI Layout -->
<style>
    :root {
        /* Premium Fresh Cyan-Lime Ecosystem Colors */
        --brand-blue: #0d6efd;
        --brand-cyan: #06b6d4;
        --brand-lime: #84cc16;
        --brand-emerald: #10b981;
        /* Advanced Gradients */
        --primary-gradient: linear-gradient(135deg, #06b6d4 0%, #0d6efd 100%);
        --cyan-lime-gradient: linear-gradient(135deg, #06b6d4 0%, #10b981 50%, #84cc16 100%);
        /* Light Gradient for Stats Panel (Replaced Dark Background from image_c728e8.png) */
        --stats-light-gradient: linear-gradient(135deg, #f0fdfa 0%, #f6fee8 100%);
        --text-main: #0f172a;
        --text-muted: #475569;
        --text-secondary: #64748b;
    }

    body {
        background-color: #ffffff;
    }

    /* Common Components */
    .section-spacing {
        padding: 90px 0;
    }

    .badge-premium {
        background: rgba(6, 114, 212, 0.08);
        color: #0891b2;
        font-weight: 600;
        font-size: 0.85rem;
        padding: 0.6rem 1.4rem;
        border-radius: 50px;
        letter-spacing: 0.5px;
        display: inline-block;
    }

    .gradient-heading {
        background: linear-gradient(135deg, #0f172a 30%, #1e293b 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .gradient-brand-text {
        background: var(--cyan-lime-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .btn-gradient-main {
        background: var(--primary-gradient);
        color: white !important;
        border: none;
        box-shadow: 0 4px 14px rgba(6, 182, 212, 0.3);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .btn-gradient-main:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(13, 110, 253, 0.4);
        }

    .btn-outline-modern {
        border: 2px solid #e2e8f0;
        color: var(--text-main);
        font-weight: 500;
        transition: all 0.3s ease;
    }

        .btn-outline-modern:hover {
            background-color: #f8fafc;
            border-color: #cbd5e1;
        }

    /* 1. Hero Area */
    .hero-wrapper {
        background: radial-gradient(circle at 80% 20%, rgba(6, 182, 212, 0.06) 0%, rgba(13, 110, 253, 0.02) 50%, #ffffff 100%);
        padding: 120px 0 90px 0;
    }

    .hero-img-box {
        position: relative;
    }

        .hero-img-box::before {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            top: 15px;
            left: 15px;
            background: var(--cyan-lime-gradient);
            border-radius: 24px;
            z-index: 1;
            opacity: 0.15;
            filter: blur(10px);
        }

    /* 2. Solutions Rich Cards */
    .solution-card {
        background: #ffffff;
        border: 1px solid #f1f5f9;
        border-radius: 24px;
        padding: 40px 30px;
        transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .solution-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(6, 182, 212, 0.08);
            border-color: #e2e8f0;
        }

    .icon-wrapper {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        margin-bottom: 25px;
    }

    /* 3. Upgraded Stats Section (Replaced Dark Background with Light Gradient) */
    .stats-bar {
        background: var(--stats-light-gradient);
        border: 1px solid rgba(6, 182, 212, 0.15);
        color: var(--text-main);
        border-radius: 32px;
        padding: 50px;
        box-shadow: 0 15px 35px rgba(6, 182, 212, 0.04);
    }

    /* High-contrast colors for numbers over the light background */
    .stat-number-cyan {
        color: #0891b2 !important; /* Deep Premium Cyan */
        font-weight: 800;
    }

    .stat-number-lime {
        color: #16a34a !important; /* Deep Emerald Green */
        font-weight: 800;
    }

    .stat-number-bright {
        color: #0284c7 !important; /* Royal Sky Blue */
        font-weight: 800;
    }

    /* Highly visible text labels on light bg */
    .stat-desc {
        color: #475569 !important;
        font-size: 0.85rem;
        letter-spacing: 0.75px;
        font-weight: 700;
        margin-top: 6px;
    }

    /* 4. Specialist Profiles */
    .doctor-profile-card {
        background: #ffffff;
        border: 1px solid #f1f5f9;
        border-radius: 24px;
        overflow: hidden;
        transition: all 0.3s ease;
    }

        .doctor-profile-card:hover {
            box-shadow: 0 12px 30px rgba(6, 182, 212, 0.06);
            border-color: #06b6d4;
        }

    .doc-avatar {
        height: 260px;
        object-fit: cover;
        width: 100%;
    }

    /* 5. Process Steps */
    .step-circle {
        width: 50px;
        height: 50px;
        background: rgba(6, 182, 212, 0.1);
        color: #06b6d4;
        font-weight: 700;
        border-radius: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }

    /* 6. Testimonials */
    .review-bubble {
        background: #ffffff;
        border: 1px solid #f1f5f9;
        border-radius: 24px;
        padding: 35px;
        height: 100%;
        transition: border 0.3s;
    }

        .review-bubble:hover {
            border-color: rgba(16, 185, 129, 0.2);
        }
</style>

<!-- ========================= HERO SECTION ========================= -->
<section class="hero-wrapper">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 text-center text-lg-start">
                <div class="badge-premium mb-3">
                    ✨ Next-Gen Cyan-Lime Medical Platform
                </div>
                <h1 class="display-3 fw-extrabold hero-title gradient-heading mb-4" style="font-weight:800; letter-spacing:-1.5px;">
                    Your Digital <br><span class="gradient-brand-text">Healthcare</span> Ecosystem
                </h1>
                <p class="fs-5 text-secondary mb-5" style="max-width: 550px; line-height: 1.7;">
                    Access global medical expertise. Instantly request delivery for critical medications, clear digital health logs, and route priority telehealth sessions securely.
                </p>
                <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-lg-start">
                    <a href="#solutions" class="btn btn-gradient-main btn-lg px-5 py-3 fw-semibold">View Operations</a>
                    <a href="#workflow" class="btn btn-outline-modern btn-lg px-5 py-3">How it Works</a>
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <div class="hero-img-box">
                    <img src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&fit=crop&w=650&q=80"
                         alt="E-Medic Digital Hub" class="img-fluid position-relative rounded-4" style="z-index: 2; max-height:430px; object-fit:cover;">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========================= STATS BENCHMARK (Replaced Dark Background with Soft Light Gradient) ========================= -->
<section class="container my-5">
    <div class="stats-bar">
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <h3 class="display-5 fw-bold stat-number-cyan mb-1">99.4%</h3>
                <p class="stat-desc text-uppercase mb-0">Prescription Precision</p>
            </div>
            <div class="col-md-4 border-start border-end border-secondary border-opacity-25">
