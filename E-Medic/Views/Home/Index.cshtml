                    <p class="text-secondary small mb-4">End-to-end encrypted ledger syncing appointment diagnostics logs under strict user configuration authorization parameters.</p>
                    <a href="#" class="text-success text-decoration-none fw-semibold small" style="color: #84cc16 !important;">Access Dashboard &rarr;</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========================= PIPELINE WORKFLOW ========================= -->
<section id="workflow" class="section-spacing border-top border-bottom" style="background-color: #f8fafc;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-6 fw-bold gradient-heading">How E-Medic Operates</h2>
            <p class="text-muted">A clear, optimized 3-step pipeline designed for patient agility.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="step-circle">01</div>
                <h4 class="h6 fw-bold">Submit Query or Script</h4>
                <p class="text-secondary small">Input clinical requirements or drop prescription payloads into our encrypted gateway architecture securely.</p>
            </div>
            <div class="col-md-4">
                <div class="step-circle">02</div>
                <h4 class="h6 fw-bold">Clinical Verification</h4>
                <p class="text-secondary small">Automated filters query verified pharmacist frameworks or connect direct live-matching with global consultants within seconds.</p>
            </div>
            <div class="col-md-4">
                <div class="step-circle">03</div>
                <h4 class="h6 fw-bold">Dispatch Optimization</h4>
                <p class="text-secondary small">Your approved payload routes through instant home delivery vectors or displays real-time secure treatment plans instantly.</p>
            </div>
        </div>
    </div>
</section>

