<style>
    :root {
        --brand-dark: #0f172a;
        --brand-cyan: #06b6d4;
        --brand-lime: #84cc16;
        --brand-emerald: #10b981;
        --glass-bg: rgba(255, 255, 255, 0.45);
        --glass-border: rgba(255, 255, 255, 0.25);
        --cyan-lime-gradient: linear-gradient(135deg, #06b6d4 0%, #10b981 50%, #84cc16 100%);
        --primary-gradient: linear-gradient(135deg, #06b6d4 0%, #0d6efd 100%);
        --dark-surface: #0b1329;
    }

    body {
        background-color: #fafdfd;
        color: var(--brand-dark);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        overflow-x: hidden;
    }

    /* Ambient Floating Animated Blobs */
    .blob-wrapper {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        z-index: -1;
        overflow: hidden;
        pointer-events: none;
    }

    .blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.12;
        animation: floatBubble 12s infinite alternate ease-in-out;
    }

    .blob-1 {
        width: 400px;
        height: 400px;
        background: var(--brand-cyan);
        top: -10%;
        right: -5%;
    }

    .blob-2 {
        width: 500px;
        height: 500px;
        background: var(--brand-lime);
        top: 40%;
        left: -10%;
        animation-delay: 2s;
    }

    .blob-3 {
        width: 350px;
        height: 350px;
        background: #0d6efd;
        bottom: 5%;
        right: 10%;
        animation-delay: 4s;
    }

    /* CSS keyframes thoroughly escaped for Razor compilation */
    @@keyframes floatBubble {
        0% {
            transform: translateY(0px) scale(1);
        }

        100% {
            transform: translateY(40px) scale(1.1);
        }
    }

    /* Section Spacing */
    .section-padding {
        padding: 120px 0;
    }

    /* Glassmorphism Premium Utilities */
    .glass-card {
        background: rgba(255, 255, 255, 0.65);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(6, 182, 212, 0.15);
        border-radius: 24px;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* Badge Design */
    .badge-modern {
        background: linear-gradient(135deg, rgba(6, 182, 212, 0.1) 0%, rgba(132, 204, 22, 0.1) 100%);
        border: 1px solid rgba(6, 182, 212, 0.2);
        color: #0891b2;
        font-weight: 600;
        padding: 0.6rem 1.4rem;
        border-radius: 50px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    /* Typography Gradients - Modern CSS Standards */
    .text-gradient-headline {
        background: linear-gradient(135deg, #0f172a 20%, #334155 100%);
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .text-gradient-brand {
        background: var(--cyan-lime-gradient);
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Button Layouts */
    .btn-premium-main {
        background: var(--primary-gradient);
        color: #ffffff !important;
        border: none;
        border-radius: 14px;
        padding: 14px 32px;
        box-shadow: 0 8px 24px rgba(6, 182, 212, 0.25);
        transition: all 0.3s ease;
    }

        .btn-premium-main:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 30px rgba(13, 110, 253, 0.35);
        }

    .btn-premium-outline {
        border: 2px solid #e2e8f0;
        background: transparent;
        color: var(--brand-dark);
        border-radius: 14px;
        padding: 12px 32px;
        transition: all 0.3s ease;
    }

        .btn-premium-outline:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
        }

    /* Hero Component Customizations */
    .hero-container {
        position: relative;
        padding: 140px 0 100px 0;
    }

    .hero-interactive-img {
        position: relative;
        border-radius: 32px;
        box-shadow: 0 30px 60px rgba(15, 23, 42, 0.08);
        transition: transform 0.5s ease;
    }

        .hero-interactive-img:hover {
            transform: scale(1.02);
        }

    /* Feature/Solution Matrix Cards */
    .matrix-card {
        padding: 45px 35px;
        height: 100%;
    }

        .matrix-card:hover {
            transform: translateY(-10px);
            border-color: rgba(6, 182, 212, 0.4);
            box-shadow: 0 20px 40px rgba(6, 182, 212, 0.06);
        }

    .matrix-icon-box {
        width: 64px;
        height: 64px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        margin-bottom: 30px;
    }

    /* Step Workflows */
    .workflow-step-badge {
        font-size: 2.5rem;
        font-weight: 800;
        background: linear-gradient(135deg, rgba(6, 182, 212, 0.2) 0%, rgba(132, 204, 22, 0.2) 100%);
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        line-height: 1;
    }

    /* Dark Feature Showroom */
    .dark-showroom-section {
        background: var(--dark-surface);
        color: #ffffff;
        border-radius: 40px;
        padding: 90px 60px;
        position: relative;
    }

    /* Specialist Grid Cards */
    .expert-card {
        background: #ffffff;
        border: 1px solid #f1f5f9;
        border-radius: 24px;
        overflow: hidden;
        transition: all 0.3s ease;
    }

        .expert-card:hover {
            border-color: var(--brand-cyan);
            box-shadow: 0 15px 35px rgba(6, 182, 212, 0.08);
            transform: translateY(-5px);
        }

    /* Testimonial Slider/Bubble styles */
    .testimonial-item {
        padding: 40px;
        border: 1px solid rgba(16, 185, 129, 0.15);
    }
</style>

