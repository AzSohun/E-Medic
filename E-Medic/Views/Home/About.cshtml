@{
    ViewData["Title"] = "About Us - Our Mission & Healthcare Infrastructure";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --ab-primary: #0284c7;
        --ab-dark: #0f172a;
        --ab-body: #475569;
        --ab-bg: #f8fafc;
    }

    .about-hero {
        background: linear-gradient(180deg, #ffffff 0%, var(--ab-bg) 100%);
        padding: 80px 0 60px 0;
    }

    .stat-box {
        border-right: 1px solid #e2e8f0;
    }

    @@media (max-width: 768px) {
        .stat-box {
            border-right: none;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 20px;
            margin-bottom: 20px;
        }
    }

    .core-value-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 32px 24px;
        transition: all 0.2s ease;
    }

        .core-value-card:hover {
            border-color: #cbd5e1;
            box-shadow: 0 10px 25px rgba(15, 23, 42, 0.03);
        }
</style>

<section class="about-hero">
    <div class="container text-center">
        <span class="badge rounded-pill px-3 py-2 mb-3" style="background-color: rgba(2, 132, 199, 0.08); color: var(--ab-primary); font-weight: 600; font-size: 0.85rem;">
            INSIDE E-MEDIC
        </span>
        <h1 class="display-4 fw-bold text-dark mb-3" style="letter-spacing: -1px; color: var(--ab-dark) !important;">
            We are Transforming <br><span style="color: var(--ab-primary);">Virtual Healthcare Delivery.</span>
        </h1>
        <p class="fs-5 text-muted mx-auto mb-5" style="max-width: 620px; line-height: 1.6;">
            E-Medic is a premium clinical trust infrastructure built to bridge the gap between world-class medical specialists and patient triage management.
        </p>
    </div>
</section>

<section class="py-5 border-top border-bottom bg-white">
    <div class="container py-3">
        <div class="row text-center g-4">
            <div class="col-md-4 stat-box">
                <h2 class="display-5 fw-bold text-dark mb-1" style="color: var(--ab-dark) !important;">99.4%</h2>
                <p class="small text-muted fw-semibold uppercase tracking-wider mb-0">DIAGNOSTIC ACCURACY RATE</p>
            </div>
            <div class="col-md-4 stat-box">
                <h2 class="display-5 fw-bold text-dark mb-1" style="color: var(--ab-dark) !important;">12 min</h2>
                <p class="small text-muted fw-semibold uppercase tracking-wider mb-0">AVERAGE RESPONSE TIME</p>
            </div>
            <div class="col-md-4 border-0">
                <h2 class="display-5 fw-bold text-dark mb-1" style="color: var(--ab-dark) !important;">150+</h2>
                <p class="small text-muted fw-semibold uppercase tracking-wider mb-0">VERIFIED CLINICAL SPECIALISTS</p>
            </div>
        </div>
    </div>
</section>

<section class="py-5" style="background-color: #ffffff; padding: 80px 0 !important;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold text-dark" style="letter-spacing: -0.5px;">Our Core Principles</h2>
            <p class="text-muted small">The architectural standard behind every virtual encounter.</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="core-value-card">
                    <div class="d-flex align-items-center justify-content-center rounded-3 mb-4" style="width: 44px; height: 44px; background-color: rgba(2, 132, 199, 0.08); color: var(--ab-primary);">
                        <i class="bi bi-shield-lock-fill fs-5"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark mb-2">Absolute Privacy</h3>
                    <p class="small text-secondary mb-0" style="line-height: 1.6;">Every clinical prescription, telemetry log, and medical record is secured via zero-knowledge data architecture layers.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="core-value-card">
                    <div class="d-flex align-items-center justify-content-center rounded-3 mb-4" style="width: 44px; height: 44px; background-color: rgba(16, 185, 129, 0.08); color: #10b981;">
                        <i class="bi bi-lightning-charge-fill fs-5"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark mb-2">Real-Time Routing</h3>
                    <p class="small text-secondary mb-0" style="line-height: 1.6;">Our dynamic query structure reduces live session queuing latency down to seconds, matching you with appropriate active care providers.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="core-value-card">
                    <div class="d-flex align-items-center justify-content-center rounded-3 mb-4" style="width: 44px; height: 44px; background-color: rgba(234, 179, 8, 0.08); color: #eab308;">
                        <i class="bi bi-heart-pulse-fill fs-5"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark mb-2">Vetted Expertise</h3>
                    <p class="small text-secondary mb-0" style="line-height: 1.6;">Only board-certified medical practitioners with verifiable license logs are integrated into the E-Medic clinical directory.</p>
                </div>
            </div>
        </div>
    </div>
</section>