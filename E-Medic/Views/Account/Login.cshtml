@model E_Medic.DTOs.LoginDto
@{
    ViewData["Title"] = "Login";
}

<div class="container d-flex flex-column justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="row w-100 justify-content-center">
        <div class="col-12 col-sm-10 col-md-7 col-lg-5 col-xl-4 bg-white border border-0 shadow-lg rounded-4 p-4 p-sm-5" style="box-shadow: 0 20px 40px rgba(0,0,0,0.06) !important;">

            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-3 mb-3" style="width: 50px; height: 50px; background: rgba(6, 182, 212, 0.08); border: 1px solid rgba(6, 182, 212, 0.15);">
                    <i class="bi bi-plus-lg text-info fs-3" style="color: #06b6d4 !important;"></i>
                </div>
                <h2 class="fw-bold text-dark tracking-tight mb-1" style="font-weight: 800; font-size: 1.85rem; letter-spacing: -0.75px;">Welcome Back</h2>
                <p class="text-secondary small">Please sign in to access your E-Medic secure portal</p>
            </div>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 small border-0 rounded-3 mb-4" style="background-color: #fef2f2; color: #991b1b;"></div>

                <div class="mb-3">
                    <label class="form-label fw-bold small text-secondary mb-1" style="font-size: 0.8rem; letter-spacing: 0.3px; text-transform: uppercase;">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted px-3"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control bg-light border-start-0 ps-2 shadow-none modern-input" placeholder="name@example.com" required />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block" style="font-size: 0.78rem;"></span>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label class="form-label fw-bold small text-secondary mb-0" style="font-size: 0.8rem; letter-spacing: 0.3px; text-transform: uppercase;">Password</label>
                        <a href="#" class="text-decoration-none small fw-bold" style="color: #06b6d4; font-size: 0.8rem;">Forgot?</a>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted px-3"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" type="password" id="txtLoginPassword" class="form-control bg-light border-start-0 border-end-0 ps-2 shadow-none modern-input" placeholder="••••••••" required />
                        <button class="input-group-text bg-light border-start-0 text-muted px-3 toggle-password-btn" type="button" data-target="txtLoginPassword">
                            <i class="bi bi-eye-slash"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block" style="font-size: 0.78rem;"></span>
                </div>

                <div class="form-check d-flex align-items-center gap-2 mb-4">
                    <input asp-for="RememberMe" class="form-check-input shadow-none modern-checkbox" type="checkbox" style="cursor: pointer; width: 17px; height: 17px; margin: 0;" />
                    <label asp-for="RememberMe" class="form-check-label small text-secondary fw-medium" style="cursor: pointer; user-select: none; line-height: 1;">
                        Remember me on this device
                    </label>
                </div>

                <button type="submit" class="btn btn-login-submit py-2.5 rounded-3 fw-bold w-100 border-0" style="font-size: 0.95rem; letter-spacing: 0.3px;">
                    Sign In
                </button>
            </form>

            <div class="mt-4 text-center">
                <p class="small text-secondary mb-0">
                    Don't have an account?
                    <a asp-action="Register" class="text-decoration-none fw-bold ms-1" style="color: #06b6d4;">Register here</a>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .modern-input {
        border-radius: 8px !important;
        border: 1px solid #e2e8f0 !important;
        padding-top: 0.65rem !important;
        padding-bottom: 0.65rem !important;
        font-size: 0.9rem !important;
        background-color: #f8fafc !important;
        transition: all 0.2s ease-in-out !important;
    }

    .input-group > .input-group-text {
        border-top-left-radius: 8px !important;
        border-bottom-left-radius: 8px !important;
        border: 1px solid #e2e8f0 !important;
        border-right: none !important;
        background-color: #f8fafc !important;
    }

    .input-group > .toggle-password-btn {
        border-top-right-radius: 8px !important;
        border-bottom-right-radius: 8px !important;
        border: 1px solid #e2e8f0 !important;
        border-left: none !important;
        background-color: #f8fafc !important;
        cursor: pointer;
    }

    .input-group > .modern-input {
        border-top-left-radius: 0 !important;
        border-bottom-left-radius: 0 !important;
        border-top-right-radius: 0 !important;
        border-bottom-right-radius: 0 !important;
    }

    .modern-input:focus, .modern-input:focus + .toggle-password-btn {
        background-color: #ffffff !important;
        border-color: #06b6d4 !important;
    }

    .modern-checkbox {
        border: 1px solid #cbd5e1 !important;
        border-radius: 4px !important;
        transition: all 0.15s ease-in-out;
    }

        .modern-checkbox:checked {
            background-color: #06b6d4 !important;
            border-color: #06b6d4 !important;
        }

    .btn-login-submit {
        background: linear-gradient(135deg, #06b6d4 0%, #0284c7 100%) !important;
        color: white !important;
        box-shadow: 0 4px 14px rgba(6, 182, 212, 0.2);
        transition: all 0.2s ease;
    }

        .btn-login-submit:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(2, 132, 199, 0.3);
            opacity: 0.95;
        }
</style>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        document.querySelectorAll('.toggle-password-btn').forEach(button => {
            button.addEventListener('click', function () {
                const targetId = this.getAttribute('data-target');
                const passwordInput = document.getElementById(targetId);
                const icon = this.querySelector('i');

                if (passwordInput.type === 'password') {
                    passwordInput.type = 'text';
                    icon.classList.remove('bi-eye-slash');
                    icon.classList.add('bi-eye');
                } else {
                    passwordInput.type = 'password';
                    icon.classList.remove('bi-eye');
                    icon.classList.add('bi-eye-slash');
                }
            });
        });
    </script>
}