@model E_Medic.DTOs.RegisterDto
@{
    ViewData["Title"] = "Register";
}

<div class="container d-flex flex-column justify-content-center align-items-center my-5">
    <div class="row w-100 justify-content-center">
        <div class="col-12 col-sm-11 col-md-10 col-lg-9 col-xl-8 bg-white border border-0 shadow-lg rounded-4 p-4 p-sm-5" style="box-shadow: 0 20px 40px rgba(0,0,0,0.06) !important;">

            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center rounded-3 mb-2" style="width: 46px; height: 46px; background: rgba(6, 182, 212, 0.08); border: 1px solid rgba(6, 182, 212, 0.15);">
                    <i class="bi bi-plus-lg text-info fs-4" style="color: #06b6d4 !important;"></i>
                </div>
                <h2 class="fw-bold text-dark tracking-tight mb-1" style="font-weight: 800; font-size: 1.85rem; letter-spacing: -0.75px;">Create Account</h2>
                <p class="text-secondary small">Join the E-Medic healthcare ecosystem today</p>
            </div>

            <form asp-controller="Account" asp-action="Register" method="post">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger py-2 px-3 small border-0 rounded-3 mb-4" style="background-color: #fef2f2; color: #991b1b; font-weight: 600;"></div>
                }

                <div class="row g-3">

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-secondary mb-1" style="font-size: 0.8rem; letter-spacing: 0.3px; text-transform: uppercase;">Full Name</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted px-3"><i class="bi bi-person"></i></span>
                            <input asp-for="FullName" class="form-control bg-light border-start-0 ps-2 shadow-none modern-input" placeholder="John Doe" required />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small mt-1 d-block" style="font-size: 0.78rem;"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-secondary mb-1" style="font-size: 0.8rem; letter-spacing: 0.3px; text-transform: uppercase;">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted px-3"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control bg-light border-start-0 ps-2 shadow-none modern-input" placeholder="name@example.com" required />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block" style="font-size: 0.78rem;"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-secondary mb-1" style="font-size: 0.8rem; letter-spacing: 0.3px; text-transform: uppercase;">Phone Number</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted px-3"><i class="bi bi-telephone"></i></span>
                            <input asp-for="PhoneNumber" class="form-control bg-light border-start-0 ps-2 shadow-none modern-input" placeholder="+8801XXXXXXXXX" />
                        </div>
                        <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block" style="font-size: 0.78rem;"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-secondary mb-1" style="font-size: 0.8rem; letter-spacing: 0.3px; text-transform: uppercase;">Date of Birth</label>
                        <input asp-for="DateOfBirth" type="date" class="form-control bg-light shadow-none modern-input" required />
                        <span asp-validation-for="DateOfBirth" class="text-danger small mt-1 d-block" style="font-size: 0.78rem;"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-secondary mb-2" style="font-size: 0.8rem; letter-spacing: 0.3px; text-transform: uppercase;">Gender</label>
                        <div class="d-flex gap-2 custom-segmented-group">
                            <div class="flex-grow-1">
                                <input type="radio" class="btn-check" asp-for="Gender" value="Male" id="genderMale" checked>
                                <label class="btn btn-outline-modern-pill w-100 py-2 px-2" for="genderMale">
                                    <i class="bi bi-gender-male me-1"></i> Male
                                </label>
                            </div>
                            <div class="flex-grow-1">
                                <input type="radio" class="btn-check" asp-for="Gender" value="Female" id="genderFemale">
                                <label class="btn btn-outline-modern-pill w-100 py-2 px-2" for="genderFemale">
                                    <i class="bi bi-gender-female me-1"></i> Female
                                </label>
                            </div>
                            <div class="flex-grow-1">
                                <input type="radio" class="btn-check" asp-for="Gender" value="Other" id="genderOther">
                                <label class="btn btn-outline-modern-pill w-100 py-2 px-2" for="genderOther">
                                    <i class="bi bi-gender-ambiguous me-1"></i> Other
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="Gender" class="text-danger small mt-1 d-block" style="font-size: 0.78rem;"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-secondary mb-2" style="font-size: 0.8rem; letter-spacing: 0.3px; text-transform: uppercase;">Register As</label>
                        <div class="row g-2">
                            <div class="col-6">
                                <input type="radio" class="btn-check" asp-for="Role" value="Patient" id="rolePatient" checked>
                                <label class="btn btn-outline-modern-pill w-100 py-2 px-2 d-flex align-items-center justify-content-center gap-2" for="rolePatient">
                                    <i class="bi bi-person-bounding-box"></i>
                                    <span class="fw-bold small mb-0">Patient</span>
                                </label>
                            </div>
                            <div class="col-6">
                                <input type="radio" class="btn-check" asp-for="Role" value="Doctor" id="roleDoctor">
                                <label class="btn btn-outline-modern-pill w-100 py-2.5 px-2 d-flex align-items-center justify-content-center gap-2" for="roleDoctor">
                                    <i class="bi bi-heart-pulse"></i>
                                    <span class="fw-bold small mb-0">Doctor</span>
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="Role" class="text-danger small mt-1 d-block" style="font-size: 0.78rem;"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-secondary mb-1" style="font-size: 0.8rem; letter-spacing: 0.3px; text-transform: uppercase;">Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted px-3"><i class="bi bi-lock"></i></span>
                            <input asp-for="Password" type="password" class="form-control bg-light border-start-0 border-end-0 ps-2 shadow-none modern-input" placeholder="••••••••" required />
                            <button class="input-group-text bg-light border-start-0 text-muted px-3 toggle-password-btn" type="button" data-target="Password">
                                <i class="bi bi-eye-slash"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small mt-1 d-block" style="font-size: 0.78rem;"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-secondary mb-1" style="font-size: 0.8rem; letter-spacing: 0.3px; text-transform: uppercase;">Confirm Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted px-3"><i class="bi bi-shield-check"></i></span>
                            <input asp-for="ConfirmPassword" type="password" class="form-control bg-light border-start-0 border-end-0 ps-2 shadow-none modern-input" placeholder="••••••••" required />
                            <button class="input-group-text bg-light border-start-0 text-muted px-3 toggle-password-btn" type="button" data-target="ConfirmPassword">
                                <i class="bi bi-eye-slash"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block" style="font-size: 0.78rem;"></span>
                    </div>

                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-register-submit py-2.5 rounded-3 fw-bold w-100 border-0" style="font-size: 0.95rem; letter-spacing: 0.3px;">
                        Register Account
                    </button>
                </div>
            </form>

            <div class="mt-4 text-center">
                <p class="small text-secondary mb-0">
                    Already have an account?
                    <a asp-action="Login" class="text-decoration-none fw-bold ms-1" style="color: #06b6d4;">Login here</a>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    /* Premium Input System Rules */
    .modern-input {
        border-radius: 8px !important;
        border: 1px solid #e2e8f0 !important;
        padding-top: 0.65rem !important;
        padding-bottom: 0.65rem !important;
        font-size: 0.9rem !important;
        background-color: #f8fafc !important;
        transition: all 0.2s ease-in-out !important;
    }

    .input-group > .input-group-text {
        border-top-left-radius: 8px !important;
        border-bottom-left-radius: 8px !important;
        border: 1px solid #e2e8f0 !important;
        border-right: none !important;
        background-color: #f8fafc !important;
    }

    .input-group > .toggle-password-btn {
        border-top-right-radius: 8px !important;
        border-bottom-right-radius: 8px !important;
        border: 1px solid #e2e8f0 !important;
        border-left: none !important;
        background-color: #f8fafc !important;
        cursor: pointer;
    }

    .input-group > .modern-input {
        border-top-left-radius: 0 !important;
        border-bottom-left-radius: 0 !important;
        border-top-right-radius: 0 !important;
        border-bottom-right-radius: 0 !important;
    }

    .modern-input:focus, .modern-input:focus + .toggle-password-btn {
        background-color: #ffffff !important;
        border-color: #06b6d4 !important;
    }

    /* Interlocking Segmented Pill Styling */
    .btn-outline-modern-pill {
        border: 1px solid #e2e8f0;
        background-color: #ffffff;
        color: #475569;
        border-radius: 8px;
        font-size: 0.88rem;
        font-weight: 600;
        transition: all 0.2s ease;
        cursor: pointer;
    }

        .btn-outline-modern-pill:hover {
            background-color: #f8fafc;
            border-color: #cbd5e1;
            color: #1e293b;
        }

    /* Activated Custom Pill Styling */
    .btn-check:checked + .btn-outline-modern-pill {
        background-color: #ecfeff !important;
        border-color: #06b6d4 !important;
        color: #0891b2 !important;
        box-shadow: 0 2px 8px rgba(6, 182, 212, 0.06) !important;
    }

    /* Linear Cyan-Blue Master Gradient Button Configuration */
    .btn-register-submit {
        background: linear-gradient(135deg, #06b6d4 0%, #0284c7 100%) !important;
        color: white !important;
        box-shadow: 0 4px 14px rgba(6, 182, 212, 0.2);
        transition: all 0.2s ease;
    }

        .btn-register-submit:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(2, 132, 199, 0.3);
            opacity: 0.95;
        }
</style>

@section Scripts {
    <script>
        // Password and Confirm Password Eye Toggle Logic
        document.querySelectorAll('.toggle-password-btn').forEach(button => {
            button.addEventListener('click', function () {
                const targetId = this.getAttribute('data-target');
                const passwordInput = document.getElementById(targetId);
                const icon = this.querySelector('i');

                if (passwordInput.type === 'password') {
                    passwordInput.type = 'text';
                    icon.classList.remove('bi-eye-slash');
                    icon.classList.add('bi-eye');
                } else {
                    passwordInput.type = 'password';
                    icon.classList.remove('bi-eye');
                    icon.classList.add('bi-eye-slash');
                }
            });
        });
    </script>
}