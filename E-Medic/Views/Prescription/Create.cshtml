@model E_Medic.DTOs.CreatePrescriptionDto
@{
    ViewData["Title"] = "Write Prescription";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7 card p-4 shadow-sm border-0 bg-light">
            <h3 class="text-center mb-4 text-success">
                <i class="bi bi-file-earmark-medical-fill"></i> Medical Record & Prescription Desk
            </h3>
            <hr />

            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="AppointmentId" />
                <input type="hidden" asp-for="PatientId" />
                <input type="hidden" asp-for="DoctorId" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Disease Name / Diagnosis</label>
                    <input asp-for="DiseaseName" class="form-control" placeholder="e.g., Seasonal Fever, Typhoid, Hypertension" required />
                    <span asp-validation-for="DiseaseName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Medications & Clinical Description</label>
                    <textarea asp-for="Description" rows="6" class="form-control" placeholder="Write prescription blueprint here...&#10;e.g.&#10;1. Napa Extend (1+0+1) - 5 days&#10;2. Entacyd (1+0+1) - Before meal" required></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Attach Digital Prescription / Report (PDF, Image)</label>
                    <input asp-for="AttachmentFile" type="file" class="form-control" accept=".pdf,.jpg,.jpeg,.png" />
                    <small class="text-muted d-block mt-1">Optional: You can upload handwritten prescription copy or scan copy here.</small>
                    <span asp-validation-for="AttachmentFile" class="text-danger"></span>
                </div>

                <div class="row text-center">
                    <div class="col-6">
                        <a asp-controller="Appointment" asp-action="DoctorQueue" class="btn btn-outline-secondary w-100">Back to Queue</a>
                    </div>
                    <div class="col-6">
                        <button type="submit" class="btn btn-success w-100 fw-semibold">Save & Complete Consultation</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>