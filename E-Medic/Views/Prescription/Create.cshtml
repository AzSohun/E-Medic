@model E_Medic.DTOs.CreatePrescriptionDto

@{
    ViewData["Title"] = "Write Digital Prescription";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-9">

            <div class="d-flex align-items-center gap-2 mb-4">
                <a asp-controller="Doctor" asp-action="DoctorQueue" class="btn btn-sm btn-light border rounded-circle p-2 d-inline-flex align-items-center justify-content-center" style="width:36px; height:36px;">
                    <i class="bi bi-arrow-left text-dark"></i>
                </a>
                <div>
                    <h3 class="fw-bold text-dark mb-0" style="letter-spacing: -0.5px;">Digital Consultation Desk</h3>
                    <p class="text-muted small mb-0">Formulate official prescription and telemetry diagnostics</p>
                </div>
            </div>

            <div class="card border-0 shadow rounded-4 bg-white overflow-hidden" style="box-shadow: 0 15px 35px rgba(15,23,42,0.06) !important;">

                <div class="card-header bg-light border-bottom p-4 d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-3 bg-info d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; background-color: rgba(6, 182, 212, 0.1) !important;">
                            <i class="bi bi-plus-lg text-info fs-5"></i>
                        </div>
                        <span class="fw-bold text-dark fs-5">E-MEDIC <span class="text-muted fw-normal" style="font-size:0.85rem;">| CLINICAL TRUST</span></span>
                    </div>
                    <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3 py-1.5 fw-semibold small">
                        Secure Electronic Record
                    </span>
                </div>

                <div class="card-body p-4 p-sm-5">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="AppointmentId" />
                        <input type="hidden" asp-for="PatientId" />
                        <input type="hidden" asp-for="DoctorId" />

                        <input type="hidden" asp-for="Description" id="hdnDescription" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger p-3 small border-0 rounded-3 mb-4"></div>

                        <div class="row g-4 mb-4">
                            <div class="col-12">
                                <label class="form-label fw-bold small text-secondary uppercase mb-1" style="font-size:0.75rem; letter-spacing:0.5px;">DIAGNOSIS / DISEASE NAME *</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-activity"></i></span>
                                    <input asp-for="DiseaseName" class="form-control bg-light border-start-0 ps-2 shadow-none rx-input" placeholder="e.g. Acute Hypertension, Viral Fever" required />
                                </div>
                                <span asp-validation-for="DiseaseName" class="text-danger small mt-1 d-block" style="font-size:0.78rem;"></span>
                            </div>
                        </div>

                        <hr class="my-4 opacity-25">

                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="form-label fw-bold text-dark uppercase m-0" style="font-size:0.85rem; letter-spacing:0.5px; color:#0f766e !important;">
                                    <i class="bi bi-capsule-pill me-1"></i> Rx / Medications & Instructions
                                </label>
                                <button type="button" id="btnAddMedicine" class="btn btn-sm btn-outline-info rounded-pill px-3 fw-bold" style="font-size:0.75rem;">
                                    <i class="bi bi-plus-lg me-1"></i> Add Medicine
                                </button>
                            </div>

                            <div id="medicineRowsContainer" class="d-flex flex-column gap-3 mb-3">
                                <div class="row g-2 align-items-center medicine-row p-3 border rounded-3 bg-light-subtle position-relative">
                                    <div class="col-md-4">
                                        <input type="text" class="form-control form-control-sm shadow-none med-name" placeholder="Medicine Name (e.g. Napa Extend)" required />
                                    </div>
                                    <div class="col-md-3">
                                        <input type="text" class="form-control form-control-sm shadow-none med-dose" placeholder="Dosage (e.g. 1+0+1)" required />
                                    </div>
                                    <div class="col-md-2">
                                        <input type="text" class="form-control form-control-sm shadow-none med-days" placeholder="Duration (e.g. 7 Days)" required />
                                    </div>
                                    <div class="col-md-3 pe-md-5">
                                        <input type="text" class="form-control form-control-sm shadow-none med-inst" placeholder="Instructions (e.g. After Food)" />
                                    </div>
                                    <button type="button" class="btn btn-sm btn-link text-danger position-absolute end-0 top-50 translate-middle-y me-2 btn-remove-med d-none" style="width:auto;">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4 opacity-25">

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-secondary uppercase mb-1" style="font-size:0.75rem; letter-spacing:0.5px;">ADDITIONAL INSTRUCTIONS / LAB TESTS (OPTIONAL)</label>
                            <textarea id="txtAdditionalNotes" class="form-control bg-light shadow-none rx-input" rows="3" placeholder="e.g. Complete Blood Count (CBC), Rest for 3 days..."></textarea>
                        </div>

                        <div class="row g-4 mb-5">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-secondary uppercase mb-1" style="font-size:0.75rem; letter-spacing:0.5px;">UPLOAD ATTACHMENT REPORT (IF ANY)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-file-earmark-arrow-up"></i></span>
                                    <input asp-for="AttachmentFile" type="file" class="form-control bg-light border-start-0 ps-2 shadow-none rx-input" accept=".pdf,.jpg,.jpeg,.png" />
                                </div>
                                <span asp-validation-for="AttachmentFile" class="text-danger small mt-1 d-block" style="font-size:0.78rem;"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 border-top pt-4">
                            <a asp-controller="Doctor" asp-action="DoctorQueue" class="btn btn-light border rounded-3 px-4 fw-medium small">Cancel</a>
                            <button type="submit" id="btnSubmitPrescription" class="btn btn-info text-white rounded-3 px-5 fw-bold shadow-sm" style="background: linear-gradient(135deg, #06b6d4 0%, #0284c7 100%) !important; border:none;">
                                Save & Complete Session
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .rx-input {
        border-radius: 8px !important;
        border: 1px solid #e2e8f0 !important;
        padding-top: 0.6rem !important;
        padding-bottom: 0.6rem !important;
        font-size: 0.9rem !important;
        background-color: #f8fafc !important;
        transition: all 0.2s ease;
    }

        .rx-input:focus {
            background-color: #ffffff !important;
            border-color: #06b6d4 !important;
        }

    .input-group-text {
        border-top-left-radius: 8px !important;
        border-bottom-left-radius: 8px !important;
        border: 1px solid #e2e8f0 !important;
        background-color: #f8fafc !important;
    }

    .medicine-row {
        transition: all 0.15s ease;
    }

        .medicine-row:hover {
            border-color: #cbd5e1 !important;
            background-color: #f8fafc !important;
        }
</style>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        $(document).ready(function () {
            $("#btnAddMedicine").click(function () {
                var newRow = $(".medicine-row").first().clone();
                newRow.find("input").val("");
                newRow.find(".btn-remove-med").removeClass("d-none");
                $("#medicineRowsContainer").append(newRow);
            });

            $(document).on("click", ".btn-remove-med", function () {
                $(this).closest(".medicine-row").remove();
            });

            $("form").submit(function (e) {
                var fullPrescriptionText = "";
                var medicineCount = 1;

                $(".medicine-row").each(function () {
                    var name = $(this).find(".med-name").val();
                    var dose = $(this).find(".med-dose").val();
                    var days = $(this).find(".med-days").val();
                    var inst = $(this).find(".med-inst").val();

                    if (name && dose && days) {
                        fullPrescriptionText += medicineCount + ". " + name + " ---- (" + dose + ") ---- " + days;
                        if (inst) {
                            fullPrescriptionText += " ---- [" + inst + "]";
                        }
                        fullPrescriptionText += "\n";
                        medicineCount++;
                    }
                });

                var additionalNotes = $("#txtAdditionalNotes").val();
                if (additionalNotes) {
                    fullPrescriptionText += "\n\nAdditional Instructions / Tests:\n" + additionalNotes;
                }

                $("#hdnDescription").val(fullPrescriptionText);
            });
        });
    </script>
}