@model List<E_Medic.DTOs.DoctorProfileDto>

@{
    ViewData["Title"] = "Available Doctors";
    var doctorUsers = ViewBag.DoctorUsers as List<E_Medic.Models.User>;
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="display-6 fw-bold text-dark d-flex align-items-center gap-3" style="letter-spacing: -0.5px;">
                <i class="bi bi-search text-info"></i> Available Medical Professionals
            </h1>
        </div>
        <span class="badge px-3 py-2 rounded-pill font-monospace shadow-sm" style="background-color: rgba(6, 182, 212, 0.1) !important; color: #06b6d4 !important; border: 1px solid rgba(6, 182, 212, 0.25);">SDG 3 Rural Telemedicine</span>
    </div>

    <div class="row g-4">
        @for (int i = 0; i < Model.Count; i++)
        {
            var profileData = Model[i];
            var userDetail = doctorUsers != null && doctorUsers.Count > i ? doctorUsers[i] : null;

            var imageName = profileData.ProfilePicture != null ? profileData.ProfilePicture.FileName : "doctor-default.png";

            @if (userDetail != null)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 p-4 text-center bg-white" style="border: 1px solid #e2e8f0 !important; transition: transform 0.2s ease;">

                        <div class="mx-auto mb-3 rounded-3 overflow-hidden d-flex align-items-center justify-content-center shadow-sm" style="width: 72px; height: 72px; border: 1px solid #e2e8f0;">
                            @if (!string.IsNullOrEmpty(imageName) && imageName != "doctor-default.png")
                            {
                                <img src="/uploads/@imageName" alt="Doctor Image" class="w-100 h-100 object-fit-cover" />
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center text-info" style="background-color: rgba(6, 182, 212, 0.1);">
                                    <i class="bi bi-person-pulse fs-3"></i>
                                </div>
                            }
                        </div>

                        <h3 class="h5 fw-bold text-dark mb-1" style="letter-spacing: -0.3px;">Dr. @userDetail.FullName</h3>
                        <p class="text-secondary small mb-3"><i class="bi bi-envelope me-1"></i> @userDetail.Email</p>

                        <div class="mb-3">
                            <span class="badge bg-success bg-opacity-10 text-success px-3 py-1.5 rounded-pill fw-semibold" style="font-size: 0.82rem; background-color: rgba(25, 135, 84, 0.1) !important;">
                                @profileData.Specialty
                            </span>
                        </div>

                        <div class="p-3 rounded-3 text-start mb-4" style="background-color: #f8fafc !important; border: 1px solid #e2e8f0;">
                            <p class="small text-muted mb-2"><strong>Degrees:</strong> @profileData.Qualifications</p>
                            <p class="small text-muted mb-2"><strong>Experience:</strong> @profileData.ExperienceYears Years</p>
                            <p class="small text-muted mb-2"><strong>Fee:</strong> $@profileData.ConsultationFee</p>
                            <p class="small text-muted mb-0"><strong>Chamber Hours:</strong> @profileData.AvailableHours</p>
                        </div>

                        <a asp-controller="Appointment" asp-action="Book" asp-route-doctorId="@userDetail.Id" class="btn px-4 py-2 rounded-pill w-100 fw-semibold text-white shadow-sm" style="background: linear-gradient(135deg, #06b6d4 0%, #0284c7 100%) !important; border: none; font-size: 0.88rem;">
                            <i class="bi bi-calendar-plus me-2"></i> Book Appointment
                        </a>
                    </div>
                </div>
            }
        }
    </div>
</div>