@model IEnumerable<E_Medic.Models.Doctor>
@{
    ViewData["Title"] = "Find Doctors";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-search text-primary"></i> Available Medical Professionals</h2>
        <span class="badge bg-primary fs-6">SDG 3 Rural Telemedicine</span>
    </div>

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12 text-center my-5">
                <div class="alert alert-warning py-4">
                    <i class="bi bi-exclamation-triangle fs-1 d-block mb-2"></i>
                    No approved doctors are available in the system right now.
                </div>
            </div>
        }
        else
        {
            @foreach (var doctor in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 bg-light">
                        <div class="card-body text-center d-flex flex-column justify-content-between">
                            <div>
                                <i class="bi bi-person-md text-primary display-4 mb-3 d-block"></i>
                                <h5 class="card-title fw-bold mb-1">@doctor.User?.FullName</h5>
                                <p class="text-muted small mb-3"><i class="bi bi-envelope"></i> @doctor.User?.Email</p>

                                <span class="badge bg-success mb-3 px-3 py-2">@doctor.Specialty</span>

                                <div class="text-start bg-white p-3 rounded-3 mb-3 border">
                                    <p class="mb-1"><strong>Degrees:</strong> @doctor.Qualifications</p>
                                    <p class="mb-0"><strong>Chamber Hours:</strong> @doctor.AvailableHours</p>
                                </div>
                            </div>

                            <a asp-action="Book" asp-route-doctorId="@doctor.Id" class="btn btn-primary w-100 fw-semibold mt-2">
                                <i class="bi bi-calendar-plus"></i> Book Appointment
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>