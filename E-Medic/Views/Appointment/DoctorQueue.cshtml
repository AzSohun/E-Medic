@model IEnumerable<E_Medic.Models.Appointment>
@{
    ViewData["Title"] = "Patients Queue";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-calendar-check text-success"></i> My Patients Appointment Queue</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Patient Name</th>
                        <th>Appointment Date</th>
                        <th>Problem Statement</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">No appointment requests found in your queue.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var app in Model)
                        {
                            <tr>
                                <td class="fw-bold text-dark">@app.Patient?.FullName</td>
                                <td>@app.AppointmentDate.ToString("dd MMM yyyy")</td>
                                <td class="text-truncate" style="max-width: 300px;">@app.ProblemDescription</td>
                                <td>
                                    <span class="badge @(app.Status == "Pending" ? "bg-warning text-dark" : app.Status == "Approved" ? "bg-success" : "bg-danger")">
                                        @app.Status
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (app.Status == "Pending")
                                    {
                                        <div class="d-flex justify-content-center gap-2">
                                            <form asp-action="UpdateStatus" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="appointmentId" value="@app.Id" />
                                                <input type="hidden" name="status" value="Approved" />
                                                <button type="submit" class="btn btn-sm btn-success px-3"><i class="bi bi-check-lg"></i> Approve</button>
                                            </form>
                                            <form asp-action="UpdateStatus" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="appointmentId" value="@app.Id" />
                                                <input type="hidden" name="status" value="Rejected" />
                                                <button type="submit" class="btn btn-sm btn-danger px-3"><i class="bi bi-x-lg"></i> Reject</button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No action required</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>