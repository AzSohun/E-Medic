@model E_Medic.DTOs.DoctorDashboardDto

@{
    ViewData["Title"] = "Doctor Dashboard";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Welcome Back, Doctor!</h2>
            <p class="text-muted small mb-0">Here is the summary of your practice and upcoming patients for today.</p>
        </div>
        <span class="badge bg-light text-dark border px-3 py-2 rounded-pill fw-semibold small">
            <i class="bi bi-calendar3 text-info me-1"></i> @DateTime.Now.ToString("dd MMM yyyy")
        </span>
    </div>

    <div class="row g-3 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="p-3 bg-info bg-opacity-10 text-info rounded-3 me-3">
                        <i class="bi bi-people fs-2"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-semibold mb-1">Today's Appointments</h6>
                        <h3 class="fw-bold text-dark mb-0">@Model.TodaysAppointmentsCount</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="p-3 bg-primary bg-opacity-10 text-primary rounded-3 me-3">
                        <i class="bi bi-journal-medical fs-2"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-semibold mb-1">Total Lifetime Patients</h6>
                        <h3 class="fw-bold text-dark mb-0">@Model.TotalAppointmentsCount</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="p-3 bg-success bg-opacity-10 text-success rounded-3 me-3">
                        <i class="bi bi-cash-stack fs-2"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-semibold mb-1">Total Earnings (TK)</h6>
                        <h3 class="fw-bold text-dark mb-0">@Model.TotalEarnings ৳</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h4 class="fw-bold text-dark mb-1"><i class="bi bi-hourglass-split text-info me-2"></i>Today's Patients Queue</h4>
                <p class="text-muted small mb-0">Patients listed in order of their booking times.</p>
            </div>
        </div>

        @if (Model.TodaysQueue != null && Model.TodaysQueue.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary small fw-bold">
                        <tr>
                            <th class="border-0 ps-3">Serial No</th>
                            <th class="border-0">Patient Name</th>
                            <th class="border-0">Gender</th>
                            <th class="border-0">Appointment Time</th>
                            <th class="border-0">Status</th>
                            <th class="border-0 text-end pe-3">Action</th>
                        </tr>
                    </thead>
                    <tbody class="small text-dark">
                        @foreach (var patient in Model.TodaysQueue)
                        {
                            <tr>
                                <td class="ps-3 fw-bold text-secondary">#@patient.SerialNumber.ToString("D2")</td>
                                <td class="fw-semibold">@patient.PatientName</td>
                                <td>
                                    <span class="badge @(patient.PatientGender == "Male" ? "bg-primary-subtle text-primary" : "bg-danger-subtle text-danger") px-2 py-1 rounded-pill small">
                                        @patient.PatientGender
                                    </span>
                                </td>
                                <td><i class="bi bi-clock text-muted me-1"></i> @patient.AppointmentDate.ToString("hh:mm tt")</td>
                                <td>
                                    @if (patient.Status == "Pending")
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning px-2 py-1 rounded-pill"><i class="bi bi-dot"></i> Pending</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success px-2 py-1 rounded-pill"><i class="bi bi-check"></i> Completed</span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    @if (patient.Status == "Pending")
                                    {
                                        <a asp-controller="Doctor" asp-action="AttendPatient" asp-route-id="@patient.AppointmentId" class="btn btn-info text-white btn-sm px-3 rounded-3 fw-bold border-0 shadow-sm">
                                            Attend <i class="bi bi-arrow-right-short"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-light btn-sm px-3 rounded-3 fw-bold border text-muted" disabled>
                                            Attended
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <div class="text-muted mb-3">
                    <i class="bi bi-emoji-smile fs-1 text-secondary"></i>
                </div>
                <h5 class="fw-semibold text-dark">No appointments for today!</h5>
                <p class="text-muted small">You are completely free or no patients booked a slot yet.</p>
            </div>
        }
    </div>
</div>