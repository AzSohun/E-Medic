@model E_Medic.DTOs.DoctorDashboardDto

@{
    ViewData["Title"] = "Doctor Dashboard";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Welcome Back, Doctor!</h2>
            <p class="text-muted small mb-0">Here is the summary of your practice and upcoming patients for today.</p>
        </div>
        <span class="badge bg-light text-dark border px-3 py-2 rounded-pill fw-semibold small">
            <i class="bi bi-calendar3 text-info me-1"></i> @DateTime.Now.ToString("dd MMM yyyy")
        </span>
    </div>

    <div class="row g-3 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="p-3 bg-info bg-opacity-10 text-info rounded-3 me-3">
                        <i class="bi bi-people fs-2"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-semibold mb-1">Today's Appointments</h6>
                        <h3 class="fw-bold text-dark mb-0">@Model.TodaysAppointmentsCount</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="p-3 bg-primary bg-opacity-10 text-primary rounded-3 me-3">
                        <i class="bi bi-journal-medical fs-2"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-semibold mb-1">Total Lifetime Patients</h6>
                        <h3 class="fw-bold text-dark mb-0">@Model.TotalAppointmentsCount</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="p-3 bg-success bg-opacity-10 text-success rounded-3 me-3">
                        <i class="bi bi-cash-stack fs-2"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small fw-semibold mb-1">Total Earnings (TK)</h6>
                        <h3 class="fw-bold text-dark mb-0">@Model.TotalEarnings ৳</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h4 class="fw-bold text-dark mb-1">
                    <i class="bi bi-hourglass-split text-info me-2"></i>Active Appointments & Patients Queue
                </h4>
                <p class="text-muted small mb-0">Access your live clinical desk to attend registered patients, check telemetry, and write digital prescriptions.</p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <a asp-controller="Doctor" asp-action="DoctorQueue" class="btn btn-info text-white px-4 py-2.5 rounded-3 fw-bold border-0 shadow-sm" style="background: linear-gradient(135deg, #06b6d4 0%, #0284c7 100%) !important;">
                    Open Patient Queue <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>