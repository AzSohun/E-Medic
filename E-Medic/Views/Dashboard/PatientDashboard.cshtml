@{
    ViewData["Title"] = "Patient Dashboard";
}

<div class="container mt-4">
    <div class="card p-4 shadow-sm border border-primary border-opacity-25 bg-light mb-4 rounded-3">
        <h2 class="text-primary fw-bold mb-2">Patient Care Desk</h2>
        <p class="text-secondary mb-0 fs-6">Welcome back! Manage your medical appointments, track consultation approval status, and view your complete digital prescription history.</p>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card p-4 border border-info border-opacity-25 h-100" style="background-color: #f0fdfa; border-radius: 8px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-info-dark fw-semibold small text-uppercase mb-1" style="color: #0f766e;">Total Bookings</h6>
                        <h2 class="fw-bold text-dark mb-0">@ViewBag.TotalBookings</h2>
                    </div>
                    <i class="bi bi-calendar-heart text-info display-6"></i>
                </div>
                <a asp-controller="Appointment" asp-action="FindDoctors" class="btn btn-sm btn-outline-info mt-3 fw-semibold w-100">
                    Book New Appointment
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-4 border border-warning border-opacity-25 h-100" style="background-color: #fffbec; border-radius: 8px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-warning fw-semibold small text-uppercase mb-1" style="color: #b45309;">Pending Approval</h6>
                        <h2 class="fw-bold text-dark mb-0">@ViewBag.PendingApprovals</h2>
                    </div>
                    <i class="bi bi-hourglass-split text-warning display-6"></i>
                </div>
                <span class="text-muted small mt-3.5 d-block"><i class="bi bi-info-circle"></i> Waiting for doctor's response.</span>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-4 border border-success border-opacity-25 h-100" style="background-color: #f0fdf4; border-radius: 8px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-success fw-semibold small text-uppercase mb-1" style="color: #15803d;">Completed Visits</h6>
                        <h2 class="fw-bold text-dark mb-0">@ViewBag.CompletedVisits</h2>
                    </div>
                    <i class="bi bi-patch-check text-success display-6"></i>
                </div>
                <a asp-controller="Prescription" asp-action="MyHistory" class="btn btn-sm btn-success mt-3 fw-semibold w-100">
                    View Prescriptions <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>