@{
    ViewData["Title"] = "Doctor Dashboard";
}

<div class="container mt-4">
    <div class="card p-4 shadow-sm border border-success border-opacity-25 bg-light mb-4 rounded-3">
        <h2 class="text-success fw-bold mb-2">Doctor Consultation Desk</h2>
        <p class="text-secondary mb-0 fs-6">Welcome, Doctor. View your online queue, check digital medical records, and start live chat consultations.</p>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card p-4 border border-primary border-opacity-25 rounded-3" style="background-color: #e0f2fe;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-primary fw-semibold uppercase mb-1">Active Appointments</h6>
                        <h2 class="fw-bold text-dark mb-0">@ViewBag.TodayAppointments</h2>
                    </div>
                    <i class="bi bi-calendar2-week text-primary display-6"></i>
                </div>
                <a asp-controller="Appointment" asp-action="DoctorQueue" class="btn btn-sm btn-primary mt-3 fw-semibold w-100">
                    Open Patient Queue <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card p-4 border border-secondary border-opacity-10 rounded-3" style="background-color: #f1f5f9;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-secondary fw-semibold uppercase mb-1">Completed Consultations</h6>
                        <h2 class="fw-bold text-dark mb-0">@ViewBag.CompletedConsultations</h2>
                    </div>
                    <i class="bi bi-check-circle text-secondary display-6"></i>
                </div>
                <span class="text-muted small mt-3 d-block"><i class="bi bi-info-circle"></i> Total digital prescriptions generated by you.</span>
            </div>
        </div>
    </div>
</div>