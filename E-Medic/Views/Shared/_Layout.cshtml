<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E-Medic</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/E_Medic.styles.css" asp-append-version="true" />

    <!-- Google Fonts: Inter integrated for premium look -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        /* Force full screen height layout structure */
        html, body {
        height: 100%;
        margin: 0;
        }

        body {
        font-family: 'Inter', sans-serif;
        background-color: #ffffff;
        color: #0f172a;
        display: flex;
        flex-direction: column;
        }

        /* The main container pushes footer strictly to the bottom edge */
        .main-wrapper {
        flex: 1 0 auto;
        }

        /* Fixed vertical spacing padding for tighter look */
        .modern-nav {
        background: rgba(255, 255, 255, 0.85) !important;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(241, 245, 249, 0.9) !important;
        padding: 0.6rem 0 !important;
        transition: all 0.3s ease;
        }

        /* Brand Logo Layout */
        .navbar-brand-modern {
        font-weight: 800;
        font-size: 1.5rem;
        letter-spacing: -0.8px;
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        }

        /* Added Premium Light Gradient Box behind the Cross Icon */
        .logo-icon-container {
        background: linear-gradient(135deg, #ecfeff 0%, #f0fdf4 100%);
        border: 1px solid rgba(6, 182, 212, 0.15);
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 6px rgba(6, 182, 212, 0.05);
        }

        /* Vibrant Medical Cross styling inside the container */
        .logo-icon-cross {
        font-size: 1.15rem;
        line-height: 1;
        background: linear-gradient(135deg, #06b6d4 0%, #10b981 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        display: inline-block;
        }

        .logo-text-gradient {
        background: linear-gradient(135deg, #0f172a 30%, #06b6d4 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        }

        .nav-link-modern {
        font-weight: 500;
        color: #475569 !important;
        padding: 0.4rem 1.1rem !important;
        border-radius: 8px;
        transition: all 0.2s ease;
        }

        .nav-link-modern:hover {
        color: #06b6d4 !important;
        background: rgba(6, 182, 212, 0.05);
        }

        .btn-nav-action {
        background: linear-gradient(135deg, #06b6d4 0%, #0d6efd 100%);
        color: white !important;
        font-weight: 600;
        font-size: 0.88rem;
        padding: 0.5rem 1.25rem !important;
        border-radius: 50px;
        box-shadow: 0 4px 10px rgba(6, 182, 212, 0.15);
        transition: transform 0.2s ease;
        }

        .btn-nav-action:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 14px rgba(6, 182, 212, 0.25);
        }

        /* Premium Optimized Footer Section */
        .modern-footer {
        flex-shrink: 0;
        background-color: #0f172a;
        color: #94a3b8;
        font-size: 0.9rem;
        border-top: 1px solid #1e293b;
        }

        .footer-top {
        padding: 60px 0 40px 0;
        }

        .footer-bottom {
        padding: 25px 0;
        border-top: 1px solid #1e293b;
        }

        .footer-brand-title {
        font-weight: 800;
        font-size: 1.3rem;
        letter-spacing: -0.5px;
        color: #ffffff;
        }

        .footer-heading {
        color: #ffffff;
        font-size: 0.85rem;
        font-weight: 700;
        text-uppercase: uppercase;
        letter-spacing: 1px;
        margin-bottom: 20px;
        }

        .footer-links-list {
        list-style: none;
        padding: 0;
        margin: 0;
        }

        .footer-links-list li {
        margin-bottom: 12px;
        }

        .footer-link {
        color: #94a3b8;
        text-decoration: none;
        transition: color 0.2s ease;
        font-weight: 400;
        }

        .footer-link:hover {
        color: #06b6d4;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-heart-pulse-fill"></i> E-Medic
                </a>
                <button class="navbar-brand navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-semibold" asp-controller="Dashboard" asp-action="Index">My Dashboard</a>
                            </li>

                            @if (User.IsInRole("Patient"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-primary" asp-controller="Appointment" asp-action="FindDoctors">
                                        <i class="bi bi-search"></i> Find & Book Doctor
                                    </a>
                                </li>
                            }
                            @if (User.IsInRole("Doctor"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-success" asp-controller="Appointment" asp-action="DoctorQueue">
                                        <i class="bi bi-calendar-check"></i> Patients Queue
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item d-flex align-items-center me-3">
                                <span class="navbar-text text-dark fw-bold">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                    <span class="badge bg-secondary ms-1">
                                        @(User.IsInRole("Admin") ? "Admin" : User.IsInRole("Doctor") ? "Doctor" : "Patient")
                                    </span>
                                </span>
                            </li>
                            <li class="nav-item">
                                <form class="form-inline" asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="nav-link btn btn-link text-danger border-0 py-0">
                                        <i class="bi bi-box-arrow-right"></i> Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-primary ms-2" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container main-wrapper">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="modern-footer">
        <div class="footer-top">
            <div class="container">
                <div class="row g-4">
                    <div class="col-lg-5 col-md-6">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="logo-icon-container" style="width:30px; height:30px; border-radius:8px;">
                                <span class="logo-icon-cross" style="font-size:0.95rem;">➕</span>
                            </div>
                            <span class="footer-brand-title">E-Medic</span>
                        </div>
                        <p class="small text-secondary" style="max-width: 360px; line-height: 1.6; color: #64748b !important;">
                            Next-generation health ecosystem engineering immediate drug dispatches, encrypted logs tracking, and real-time telehealth infrastructure deployment.
                        </p>
                    </div>
                    <div class="col-lg-3 col-md-6 col-6 ms-auto">
                        <h4 class="footer-heading">Platform</h4>
                        <ul class="footer-links-list">
                            <li><a class="footer-link" asp-area="" asp-controller="Home" asp-action="Index">Home Directory</a></li>
                            <li><a class="footer-link" href="#solutions">Core Solutions</a></li>
                            <li><a class="footer-link" href="#workflow">Pipeline Workflow</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-3 col-md-6 col-6">
                        <h4 class="footer-heading">Legals</h4>
                        <ul class="footer-links-list">
                            <li><a class="footer-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a></li>
                            <li><a class="footer-link" href="#">Terms of Service</a></li>
                            <li><a class="footer-link" href="#">Security Parameters</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="container">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3 text-center text-md-start">
                    <div class="small">
                        &copy; 2026 <span class="text-white fw-medium">E-Medic</span> Ecosystem Core. All rights reserved.
                    </div>
                    <div class="small text-secondary" style="color: #64748b !important;">
                        Engineered for Patient Agility.
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>