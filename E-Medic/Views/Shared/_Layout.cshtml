<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E-Medic</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/E_Medic.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
            html, body {
                height: 100%;
                margin: 0;
            }

            body {
                font-family: 'Inter', sans-serif;
                background-color: #ffffff;
                color: #0f172a;
                display: flex;
                flex-direction: column;
                -webkit-font-smoothing: antialiased;
            }

            .main-wrapper {
                flex: 1 0 auto;
            }

            /* Modern Glassmorphic Navbar Custom Styles */
            .modern-nav {
                background-color: rgba(255, 255, 255, 0.85) !important;
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                border-bottom: 1px solid #e2e8f0 !important;
                padding: 0.75rem 0 !important;
            }

            .logo-text {
                font-weight: 700;
                color: #0f172a;
                letter-spacing: -0.5px;
            }

            .logo-accent {
                color: #06b6d4;
            }

            /* High-End Clean Nav Links Interaction */
            .nav-link-custom {
                color: #475569 !important;
                font-weight: 500;
                font-size: 0.92rem;
                padding: 0.5rem 0.85rem !important;
                border-radius: 6px;
                transition: all 0.15s ease-in-out;
            }

                .nav-link-custom:hover {
                    color: #0f172a !important;
                    background-color: #f1f5f9;
                }

            /* Premium Cyan Theme Active Buttons and Badges */
            .btn-register-theme {
                background: linear-gradient(135deg, #06b6d4 0%, #0284c7 100%) !important;
                color: #ffffff !important;
                font-weight: 600;
                font-size: 0.88rem;
                border: none;
                box-shadow: 0 4px 12px rgba(6, 182, 212, 0.15);
                transition: all 0.2s ease;
            }

                .btn-register-theme:hover {
                    transform: translateY(-1px);
                    box-shadow: 0 6px 16px rgba(2, 132, 199, 0.25);
                }

            /* Ultra-Clean Slate Light Footer Layout */
            .modern-footer {
                flex-shrink: 0;
                background-color: #f8fafc !important;
                border-top: 1px solid #e2e8f0 !important;
            }

            .footer-link {
                color: #64748b !important;
                font-weight: 500;
                font-size: 0.88rem;
                transition: color 0.15s ease;
            }

                .footer-link:hover {
                    color: #06b6d4 !important;
                }

            /* Custom dropdown pointer interaction */
            .dropdown-item-custom {
                font-size: 0.88rem;
                font-weight: 500;
                transition: background-color 0.1s ease;
            }

                .dropdown-item-custom:hover {
                    background-color: #f1f5f9 !important;
                    color: #0f172a !important;
                }
    </style>
</head>
<body>

    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg navbar-light modern-nav">
            <div class="container">

                <a class="navbar-brand d-flex align-items-center gap-2 m-0 p-0" asp-controller="Home" asp-action="Index">
                    <div class="d-flex align-items-center justify-content-center rounded-3" style="width: 32px; height: 32px; background-color: rgba(6, 182, 212, 0.1); border: 1px solid rgba(6, 182, 212, 0.25);">
                        <i class="bi bi-plus-lg logo-accent fs-5"></i>
                    </div>
                    <span class="logo-text fs-4">E<span class="logo-accent">-</span>Medic</span>
                </a>

                <button class="navbar-toggler border-0 p-1 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <i class="bi bi-list fs-2 text-dark"></i>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">

                    <ul class="navbar-nav mx-auto gap-1 mt-3 mt-lg-0">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>

                            @if (User.IsInRole("Patient"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link nav-link-custom text-info" asp-controller="Appointment" asp-action="FindDoctors">
                                        <i class="bi bi-search me-1"></i> Find & Book Doctor
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link nav-link-custom" asp-controller="Prescription" asp-action="MyHistory">
                                        <i class="bi bi-clock-history me-1"></i> Medical Records
                                    </a>
                                </li>
                            }
                            @if (User.IsInRole("Doctor"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link nav-link-custom text-success" asp-controller="Appointment" asp-action="DoctorQueue">
                                        <i class="bi bi-calendar-check me-1"></i> Patients Queue
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center gap-3 m-0 p-0 mt-3 mt-lg-0">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Doctor"))
                            {
                                <li class="nav-item dropdown w-100 w-lg-auto text-center">
                                    <button class="btn btn-light dropdown-toggle d-inline-flex align-items-center gap-2 border px-3 py-1.5 rounded-pill shadow-sm"
                                            type="button" id="doctorMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-person-circle text-info fs-6"></i>
                                        <span class="text-dark fw-semibold small">@User.Identity.Name</span>
                                        <span class="badge bg-dark rounded-pill fw-medium px-2 py-0.5" style="font-size: 0.72rem;">Doctor</span>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end border-0 shadow rounded-3 mt-2" aria-labelledby="doctorMenuDropdown">
                                        <li>
                                            <a class="dropdown-item dropdown-item-custom d-flex align-items-center gap-2 py-2" asp-controller="Doctor" asp-action="CompleteProfile">
                                                <i class="bi bi-person-vcard text-info fs-6"></i> View & Edit Profile
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item dropdown-item-custom d-flex align-items-center gap-2 py-2" asp-controller="Doctor" asp-action="Dashboard">
                                                <i class="bi bi-speedometer2 text-primary fs-6"></i> Doctor Desk
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider bg-light"></li>
                                        <li>
                                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0 p-0">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item dropdown-item-custom d-flex align-items-center gap-2 py-2 text-danger bg-transparent border-0 w-100">
                                                    <i class="bi bi-box-arrow-right"></i> Logout
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <div class="d-inline-flex align-items-center gap-2 bg-light px-3 py-1.5 rounded-pill border">
                                        <i class="bi bi-person-circle text-secondary fs-6"></i>
                                        <span class="text-dark fw-semibold small">@User.Identity.Name</span>
                                        <span class="badge bg-dark rounded-pill fw-medium px-2 py-0.5" style="font-size: 0.72rem;">
                                            @(User.IsInRole("Admin") ? "Admin" : "Patient")
                                        </span>
                                    </div>
                                </li>
                                <li class="nav-item w-100 w-lg-auto">
                                    <form class="d-inline" asp-controller="Account" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn nav-link-custom text-danger border-0 w-100 bg-transparent px-3 py-1.5 d-flex align-items-center justify-content-center gap-1.5">
                                            <i class="bi bi-box-arrow-right"></i> Logout
                                        </button>
                                    </form>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item w-100 w-lg-auto">
                                <a class="nav-link nav-link-custom text-center px-4" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item w-100 w-lg-auto">
                                <a class="btn btn-register-theme px-4 py-1.5 rounded-pill w-100" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="main-wrapper">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="modern-footer py-4">
        <div class="container">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">

                <div class="d-flex align-items-center gap-2 text-secondary small">
                    <span class="text-info fw-bold" style="font-size: 1.1rem; line-height: 1;">+</span>
                    <span class="fw-bold text-dark" style="font-size: 0.95rem; letter-spacing: -0.2px;">E-Medic</span>
                    <span>&copy; 2026 All rights reserved.</span>
                </div>

                <div class="d-flex align-items-center justify-content-center gap-4">
                    <a class="text-decoration-none footer-link" asp-controller="Home" asp-action="Index">Home</a>
                    <a class="text-decoration-none footer-link" href="#solutions">Solutions</a>
                    <a class="text-decoration-none footer-link" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                    <a class="text-decoration-none footer-link" href="#">Terms</a>
                </div>

            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>