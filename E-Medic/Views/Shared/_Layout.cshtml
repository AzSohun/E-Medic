<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E-Medic</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/E_Medic.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        /* Force full screen height layout structure */
        html, body {
        height: 100%;
        margin: 0;
        }

        body {
        font-family: 'Inter', sans-serif;
        background-color: #ffffff;
        color: #0f172a;
        display: flex;
        flex-direction: column;
        }

        /* Container layout mapping wrapper to freeze dynamic sticky placement */
        .main-wrapper {
        flex: 1 0 auto;
        }

        /* Smooth backdrop filters for transparent navbar */
        .modern-nav {
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        }

        /* Branding Text Engine overrides inside bootstrap framework */
        .logo-text-gradient {
        background: linear-gradient(135deg, #0f172a 30%, #06b6d4 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        }

        /* Premium Optimized Footer Section */
        .modern-footer {
        flex-shrink: 0;
        background-color: #0f172a;
        color: #94a3b8;
        font-size: 0.9rem;
        border-top: 1px solid #1e293b;
        }

        .footer-top {
        padding: 60px 0 40px 0;
        }

        .footer-bottom {
        padding: 25px 0;
        border-top: 1px solid #1e293b;
        }
    </style>
</head>
<body>
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg navbar-light bg-white bg-opacity-75 border-bottom border-light shadow-sm py-2 modern-nav">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2 fw-extrabold fs-4" style="letter-spacing: -0.75px;" asp-area="" asp-controller="Home" asp-action="Index">
                    <div class="d-flex align-items-center justify-content-center bg-info bg-opacity-10 border border-info border-opacity-25 rounded-3" style="width: 36px; height: 36px;">
                        <i class="bi bi-plus-lg text-info fs-5"></i>
                    </div>
                    <span class="logo-text-gradient fw-bold">E-Medic</span>
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse justify-content-between align-items-center mt-3 mt-lg-0">
                    <ul class="navbar-nav gap-1 ps-lg-3">
                        <li class="nav-item">
                            <a class="nav-link px-3 py-2 rounded-2 fw-medium text-secondary hover-bg-light" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3 py-2 rounded-2 fw-medium text-dark" asp-controller="Dashboard" asp-action="Index">My Dashboard</a>
                            </li>

                            @if (User.IsInRole("Patient"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link px-3 py-2 rounded-2 fw-medium text-primary d-flex align-items-center gap-2" asp-controller="Appointment" asp-action="FindDoctors">
                                        <i class="bi bi-search"></i> Find & Book Doctor
                                    </a>
                                </li>
                            }
                            @if (User.IsInRole("Doctor"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link px-3 py-2 rounded-2 fw-medium text-success d-flex align-items-center gap-2" asp-controller="Appointment" asp-action="DoctorQueue">
                                        <i class="bi bi-calendar-check"></i> Patients Queue
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center gap-2 mt-3 mt-lg-0">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item me-lg-2">
                                <span class="d-inline-flex align-items-center gap-2 bg-light px-3 py-2 rounded-pill text-dark fw-semibold small">
                                    <i class="bi bi-person-circle text-secondary fs-6"></i> @User.Identity.Name
                                    <span class="badge bg-dark rounded-pill fw-medium px-2 py-1">
                                        @(User.IsInRole("Admin") ? "Admin" : User.IsInRole("Doctor") ? "Doctor" : "Patient")
                                    </span>
                                </span>
                            </li>
                            <li class="nav-item w-100 w-lg-auto">
                                <form class="d-inline" asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link text-danger text-decoration-none w-100 px-3 py-2 rounded-pill d-flex align-items-center justify-content-center gap-2">
                                        <i class="bi bi-box-arrow-right"></i> Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item w-100 w-lg-auto">
                                <a class="nav-link px-4 py-2 rounded-pill fw-medium text-center text-secondary" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item w-100 w-lg-auto mt-2 mt-lg-0">
                                <a class="btn btn-primary bg-gradient px-4 py-2 rounded-pill fw-semibold shadow-sm w-100" style="background-image: linear-gradient(135deg, #06b6d4 0%, #0d6efd 100%); border:none;" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="main-wrapper">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- Upgraded Sleek Footer with Soft Ambient Shade -->
    <footer class="modern-footer border-top border-light py-4" style="background: linear-gradient(135deg, #f0fdfa 0%, #f6fee8 100%); box-shadow: 0 -10px 30px rgba(6, 182, 212, 0.04);">
        <div class="container">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">

                <!-- Left: Branding & Copyright Core -->
                <div class="d-flex align-items-center gap-2">
                    <span class="logo-icon-clean" style="font-size: 1rem;">➕</span>
                    <span class="fw-bold tracking-tight text-dark" style="font-size: 1.05rem; letter-spacing: -0.3px;">E-Medic</span>
                    <span class="text-muted mx-1" style="font-size: 0.85rem;">•</span>
                    <span class="text-secondary small">&copy; 2026 All rights reserved.</span>
                </div>

                <!-- Right: High-End Minimal Horizontal Links Grid -->
                <div class="d-flex flex-wrap align-items-center justify-content-center gap-4" style="font-size: 0.88rem;">
                    <a class="text-decoration-none text-secondary hover-text-info transition-all fw-medium" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    <a class="text-decoration-none text-secondary hover-text-info transition-all fw-medium" href="#solutions">Solutions</a>
                    <a class="text-decoration-none text-secondary hover-text-info transition-all fw-medium" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                    <a class="text-decoration-none text-secondary hover-text-info transition-all fw-medium" href="#">Terms</a>
                </div>

            </div>
        </div>
    </footer>

    <!-- Extra Minor Override Helper to support clean text transition without raw CSS sheets -->
    <style>
        .hover-text-info:hover {
        color: #06b6d4 !important;
        }

        .transition-all {
        transition: all 0.2s ease-in-out;
        }

        .modern-footer {
        flex-shrink: 0;
        }
    </style>

    <!-- Extra Minor Override Helper to support clean text transition without raw CSS sheets -->
    <style>
        .hover-text-info:hover {
        color: #06b6d4 !important;
        }

        .transition-all {
        transition: all 0.2s ease-in-out;
        }
        /* Simple footer container utility variable adjustment */
        .modern-footer {
        flex-shrink: 0;
        }
    </style>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>